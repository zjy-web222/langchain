# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Ollama（qwen3-embedding:4b 输出 2560 维，与 supabase/migrations/001_langchain_documents.sql 一致）
