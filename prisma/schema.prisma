// Prisma 直连 Supabase Postgres（DATABASE_URL）
// 向量列 halfvec 通过 lib/db/vector-store.ts 中的 raw SQL 读写

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

/// LangChain 向量表（与 Supabase documents 表一致）
model Document {
  id        BigInt                       @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("halfvec(2560)")?

  @@map("documents")
}
