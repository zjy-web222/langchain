//TODO schema未更新

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

/// LangChain 向量表（与 Supabase documents 表一致）
model Document {
  id        BigInt                       @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("halfvec(2560)")?

  @@map("documents")
}
